# Required for /api/analyze and /api/sms/inbound
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — Twilio outbound SMS / WhatsApp
# Without these, sendSms() runs in demo-mode and logs the body to the server console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Set to "whatsapp" to use WhatsApp Sandbox instead of SMS
TWILIO_CHANNEL=
TWILIO_WHATSAPP_FROM=

# Optional — override the default outbound disaster-notify message
CRISIS_MESH_OUTBOUND_MESSAGE=
